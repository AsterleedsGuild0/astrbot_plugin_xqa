{
  "self_question_enabled_default": {
    "description": "新群默认启用个人问答",
    "type": "bool",
    "default": true,
    "hint": "关闭后默认不匹配或设置“我问A你答B”。"
  },
  "admin_users": {
    "description": "插件管理员用户 ID 列表",
    "type": "list",
    "default": [],
    "hint": "除 AstrBot 管理员外，列表内用户也可管理公共问答。"
  },
  "allow_group_admin_toggle_self_question": {
    "description": "允许管理员启停个人问答",
    "type": "bool",
    "default": false,
    "hint": "当前实现使用 AstrBot 管理员/插件管理员判断。"
  },
  "enable_regex_question": {
    "description": "启用正则问题",
    "type": "bool",
    "default": true
  },
  "reject_empty_regex": {
    "description": "拒绝空匹配/泛匹配问题",
    "type": "bool",
    "default": true
  },
  "reject_dangerous_regex": {
    "description": "拒绝常见危险正则",
    "type": "bool",
    "default": true
  },
  "max_question_length": {
    "description": "问题最大字符数",
    "type": "int",
    "default": 200,
    "slider": { "min": 20, "max": 1000, "step": 10 }
  },
  "max_answer_length": {
    "description": "回答最大字符数",
    "type": "int",
    "default": 1000,
    "slider": { "min": 50, "max": 5000, "step": 50 }
  },
  "max_answers_per_question": {
    "description": "单问题随机回答数量上限",
    "type": "int",
    "default": 20,
    "slider": { "min": 1, "max": 100, "step": 1 }
  },
  "max_questions_per_user_per_group": {
    "description": "单用户单群个人问答上限",
    "type": "int",
    "default": 100,
    "slider": { "min": 1, "max": 1000, "step": 10 }
  },
  "max_public_questions_per_group": {
    "description": "单群公共问答上限",
    "type": "int",
    "default": 300,
    "slider": { "min": 1, "max": 3000, "step": 10 }
  },
  "list_page_size": {
    "description": "查看列表单次显示数量",
    "type": "int",
    "default": 30,
    "slider": { "min": 5, "max": 100, "step": 5 }
  },
  "cooldown_seconds": {
    "description": "同群触发冷却秒数",
    "type": "int",
    "default": 0,
    "slider": { "min": 0, "max": 300, "step": 1 }
  },
  "storage_filename": {
    "description": "数据文件名",
    "type": "string",
    "default": "xqa_data.json"
  },
  "enable_global_question": {
    "description": "启用全群问答命令",
    "type": "bool",
    "default": false,
    "hint": "MVP 暂未实现全群写入，保留配置项。"
  },
  "permission_denied_notice": {
    "description": "权限不足时发送提示",
    "type": "bool",
    "default": true
  }
}
